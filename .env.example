# Docker Compose environment
# Copy to .env at project root and change values before production use.

MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=replace-with-strong-mongo-password
MONGO_BIND_IP=127.0.0.1
MONGO_HOST_PORT=27017

API_KEY=change-this-api-key
ADMIN_API_KEY=change-this-admin-api-key
DEVICE_TOKEN_SECRET=change-this-device-token-secret
JWT_SECRET=change-this-jwt-secret
REFRESH_TOKEN_SECRET=change-this-refresh-token-secret
CORS_ALLOW_ORIGINS=https://app.eldercare.io.vn,https://admin.eldercare.io.vn,http://localhost,http://127.0.0.1,http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1|\[::1\])(?::\d+)?$
BACKEND_BIND_IP=127.0.0.1
BACKEND_HOST_PORT=8000
NODERED_BIND_IP=127.0.0.1
NODERED_HOST_PORT=1880
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STORAGE=redis
RATE_LIMIT_GENERAL_PER_MINUTE=300
RATE_LIMIT_ESP_PER_MINUTE=1200
REDIS_URL=redis://redis:6379/0
DEVICE_CLOCK_SKEW_TOLERANCE_SECONDS=300
EXPOSE_API_DOCS=false
EXPOSE_METRICS=false
METRICS_TOKEN=
METRICS_ALLOW_IPS=127.0.0.1,::1,localhost
# Set true only briefly during controlled bootstrap, then return to false.
ALLOW_ADMIN_API_KEY_BOOTSTRAP=false

# Firebase Cloud Messaging
# Recommended for Docker Compose: keep the service account as ONE minified JSON line
# in FCM_SERVICE_ACCOUNT_JSON and only enable push after all values below are filled.
PUSH_NOTIFICATIONS_ENABLED=false
PUSH_NOTIFICATION_COOLDOWN_SECONDS=300
MONGO_PUSH_TOKENS_COLLECTION=push_tokens
FCM_PROJECT_ID=your-firebase-project-id
# Optional for non-Docker local runs. If you use this inside Docker, the path must exist inside the container.
FCM_SERVICE_ACCOUNT_PATH=
# Example:
# FCM_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-firebase-project-id","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"firebase-adminsdk-xxx@your-firebase-project-id.iam.gserviceaccount.com","client_id":"...","token_uri":"https://oauth2.googleapis.com/token"}
FCM_SERVICE_ACCOUNT_JSON=

# Cloudflare Tunnel (optional, enable with profile `cloudflare`)
CLOUDFLARE_TUNNEL_TOKEN=replace-with-cloudflare-tunnel-token
CLOUDFLARE_PUBLIC_URL=https://api.example.com
# Long-term deployment helper:
#   ./scripts/cloudflare-longterm.sh
# Quick tunnel does not need token (profile `cloudflare-quick`)
# Optional tool service profile:
#   docker compose --profile tools up -d nodered
# Development source mount:
#   docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d --build

