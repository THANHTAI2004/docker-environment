# Environment Configuration Template
# Copy this file to .env and customize for your environment

# API authentication
API_KEY=change-this-api-key
DEVICE_TOKEN_SECRET=change-this-device-token-secret
EXPOSE_API_DOCS=false

# CORS
CORS_ALLOW_ORIGINS=https://app.eldercare.io.vn,https://admin.eldercare.io.vn,http://localhost,http://127.0.0.1,http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_ORIGIN_REGEX=

# MongoDB Configuration
MONGO_URI=mongodb://admin:SecurePassword2026!@mongodb:27017
MONGO_DB=wearable
MONGO_COLLECTION=readings

# Health Monitoring Collections
MONGO_HEALTH_COLLECTION=health_readings
MONGO_ALERTS_COLLECTION=alerts
MONGO_DEVICES_COLLECTION=devices
MONGO_USERS_COLLECTION=users
MONGO_COMMANDS_COLLECTION=device_commands

# Health Monitoring Alert Thresholds
# SpO2 Thresholds
SPO2_LOW_WARNING=90.0
SPO2_LOW_CRITICAL=85.0

# Temperature Thresholds (°C)
TEMP_HIGH_WARNING=38.0
TEMP_HIGH_CRITICAL=39.5
TEMP_LOW_WARNING=35.5

# Heart Rate Thresholds (bpm)
HR_LOW_WARNING=50
HR_LOW_CRITICAL=40
HR_HIGH_WARNING=120
HR_HIGH_CRITICAL=150

# Respiratory Rate Thresholds (breaths/min)
RR_LOW_WARNING=10
RR_HIGH_WARNING=25

# ECG Quality Alerts
ECG_QUALITY_ALERT=true
ECG_LEAD_OFF_ALERT=true
