# Docker Compose environment
# Copy to .env at project root and change values before production use.

MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=replace-with-strong-mongo-password
MONGO_BIND_IP=127.0.0.1
MONGO_HOST_PORT=27017

API_KEY=change-this-api-key
ADMIN_API_KEY=change-this-admin-api-key
DEVICE_TOKEN_SECRET=change-this-device-token-secret
JWT_SECRET=change-this-jwt-secret
CORS_ALLOW_ORIGINS=https://app.eldercare.io.vn,https://admin.eldercare.io.vn,http://localhost,http://127.0.0.1,http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_ORIGIN_REGEX=
BACKEND_BIND_IP=127.0.0.1
BACKEND_HOST_PORT=8000
NODERED_BIND_IP=127.0.0.1
NODERED_HOST_PORT=1880
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STORAGE=redis
RATE_LIMIT_GENERAL_PER_MINUTE=300
RATE_LIMIT_ESP_PER_MINUTE=1200
REDIS_URL=redis://redis:6379/0
COMMAND_TTL_SECONDS=300
EXPOSE_API_DOCS=false

# Cloudflare Tunnel (optional, enable with profile `cloudflare`)
CLOUDFLARE_TUNNEL_TOKEN=replace-with-cloudflare-tunnel-token
CLOUDFLARE_PUBLIC_URL=https://api.example.com
# Long-term deployment helper:
#   ./scripts/cloudflare-longterm.sh
# Quick tunnel does not need token (profile `cloudflare-quick`)
# Optional tool service profile:
#   docker compose --profile tools up -d nodered
